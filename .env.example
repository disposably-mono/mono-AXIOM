# ─── Mono-AXIOM — Environment Variables ───────────────
# Copy this file to `.env` and fill in real values.
# The `.env` file is gitignored and must never be committed.

# ─── Provider API keys ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Local model ───────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# ─── Paths ─────────────────────────────────────────────
# Absolute path to the vault. If unset, defaults to ./mono-vault
VAULT_PATH=/home/mono/projects/mono-axiom/mono-vault

# ─── axiom-store ───────────────────────────────────────
STORE_HOST=127.0.0.1
STORE_PORT=7070

# ─── axiom-api ─────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
